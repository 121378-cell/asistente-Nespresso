# ═══════════════════════════════════════════════════════════════════════
# Nespresso Assistant - Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# Instrucciones:
# 1. Copia este archivo a .env.local
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA hagas commit de .env.local a Git
#
# Variables de Entorno para el Frontend
# ─────────────────────────────────────
# Todas las variables deben comenzar con VITE_ para estar disponibles en el cliente

# ───────────────────────────────────────────────────────────────────────
# Requeridas
# ───────────────────────────────────────────────────────────────────────

# Backend API URL
# URL base de la API del backend
# Default: http://localhost:3001
VITE_API_URL=http://localhost:3001

# Google Gemini API Key
# Obtén tu API Key en: https://aistudio.google.com/apikey
# Requerido para el asistente de IA
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ───────────────────────────────────────────────────────────────────────
# Opcionales
# ───────────────────────────────────────────────────────────────────────

# Tema por defecto
# Valores: 'dark' | 'light'
# Default: light
# VITE_DEFAULT_THEME=dark

# Supabase URL (opcional, si usas autenticación/storage)
# VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (opcional)
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ───────────────────────────────────────────────────────────────────────
# Notas
# ───────────────────────────────────────────────────────────────────────
# - Las variables VITE_ están disponibles en el código frontend
# - Las variables no VITE_ solo están disponibles en tiempo de build
# - Para más información, ver: https://vitejs.dev/guide/env-and-mode.html
