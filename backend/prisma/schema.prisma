// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODEL
}

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String
  name      String?
  repairs   SavedRepair[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model SparePart {
  id          String         @id @default(uuid())
  partNumber  String         @unique
  name        String
  family      String?
  category    String?        // ABC Category
  repairs     UsedSparePart[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model UsedSparePart {
  id          String    @id @default(uuid())
  repairId    String
  repair      SavedRepair @relation(fields: [repairId], references: [id], onDelete: Cascade)
  partId      String
  sparePart   SparePart   @relation(fields: [partId], references: [id])
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())

  @@unique([repairId, partId])
}

model SavedRepair {
  id            String    @id @default(uuid())
  name          String
  machineModel  String?
  serialNumber  String?
  timestamp     DateTime  @default(now())
  messages      Message[]
  usedParts     UsedSparePart[]
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([timestamp])
  @@index([userId])
}

model Message {
  id                String       @id @default(uuid())
  role              Role
  text              String       @db.Text
  groundingMetadata Json?
  repairId          String
  repair            SavedRepair  @relation(fields: [repairId], references: [id], onDelete: Cascade)
  attachment        Attachment?
  createdAt         DateTime     @default(now())

  @@index([repairId])
}

model Attachment {
  id        String   @id @default(uuid())
  url       String   @db.Text // Data URL can be very long
  type      String   // MIME type
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model KnowledgeDocument {
  id          String           @id @default(uuid())
  title       String
  sourceType  String           // pdf | text
  rawText     String           @db.Text
  metadata    Json?
  chunkCount  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  chunks      KnowledgeChunk[]

  @@index([createdAt])
}

model KnowledgeChunk {
  id          String            @id @default(uuid())
  documentId  String
  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex  Int
  content     String            @db.Text
  tokenCount  Int
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([documentId])
  @@index([chunkIndex])
}
