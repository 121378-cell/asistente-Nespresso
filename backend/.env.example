# ═══════════════════════════════════════════════════════════════════════
# Nespresso Assistant - Backend Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# Instrucciones:
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA hagas commit de .env a Git
#
# Variables de Entorno para el Backend
# ─────────────────────────────────────

# ───────────────────────────────────────────────────────────────────────
# Requeridas
# ───────────────────────────────────────────────────────────────────────

# Database Connection URL
# ───────────────────────
# Supabase (recomendado):
#   postgresql://postgres.[xxxxx]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# PostgreSQL local:
#   postgresql://postgres:password@localhost:5432/nespresso_assistant
#
# Obtener URL de Supabase:
#   1. Ve a https://supabase.com/
#   2. Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nespresso_assistant?schema=public"

# ───────────────────────────────────────────────────────────────────────
# AI / LLM Configuration
# ───────────────────────────────────────────────────────────────────────

# Google Gemini API Key
# Obtén tu API Key en: https://aistudio.google.com/apikey
# Requerido para el asistente de IA


# LLM Provider
# Valores: 'gemini' | 'ollama'
# Default: gemini
LLM_PROVIDER=gemini

# Ollama Model (solo si LLM_PROVIDER=ollama)
# Modelos soportados: llama3, mistral, gemma, etc.
OLLAMA_MODEL=llama3

# ───────────────────────────────────────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────────────────────────────────────

# Puerto del servidor
# Default: 3001
PORT=3001

# Entorno de ejecución
# Valores: 'development' | 'test' | 'production'
# Default: development
NODE_ENV=development

# Trust Proxy
# Habilitar si estás detrás de un proxy inverso (nginx, Cloudflare, etc.)
# Valores: 'true' | 'false' | número
# Default: false (development), true (production)
TRUST_PROXY=false

# ───────────────────────────────────────────────────────────────────────
# CORS Configuration
# ───────────────────────────────────────────────────────────────────────

# Frontend URL (permitido por CORS)
# Default: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Allowed Origins (lista separada por comas)
# Opcional: si necesitas permitir múltiples orígenes
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://tudominio.com

# ───────────────────────────────────────────────────────────────────────
# Security
# ───────────────────────────────────────────────────────────────────────

# JWT Secret Key
# ⚠️ CAMBIAR EN PRODUCCIÓN a un valor seguro
# Default: your-secret-key-change-in-production
JWT_SECRET=your-secret-key-change-in-production

# ───────────────────────────────────────────────────────────────────────
# Supabase (Opcional)
# ───────────────────────────────────────────────────────────────────────
# Solo necesario si usas Supabase para autenticación o storage

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key_here

# ───────────────────────────────────────────────────────────────────────
# Video Job Worker (Async)
# ───────────────────────────────────────────────────────────────────────
# Configuración para procesamiento asíncrono de videos

# Número máximo de reintentos para jobs fallidos
VIDEO_JOB_MAX_ATTEMPTS=3

# Tiempo base de espera entre reintentos (milisegundos)
VIDEO_JOB_RETRY_BASE_MS=2000

# Tiempo máximo de espera entre reintentos (milisegundos)
VIDEO_JOB_RETRY_MAX_MS=60000

# Ruta opcional para base de datos de jobs (default: backend/data/video-jobs.json)
# VIDEO_JOBS_DB_PATH=backend/data/video-jobs.json

# ───────────────────────────────────────────────────────────────────────
# Logging
# ───────────────────────────────────────────────────────────────────────
# Nivel de log
# Valores: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace'
# Default: info (production), debug (development)
# LOG_LEVEL=info

# ───────────────────────────────────────────────────────────────────────
# Notas
# ───────────────────────────────────────────────────────────────────────
# - Las contraseñas no deben contener caracteres especiales sin escape
# - En producción, usa variables de entorno del sistema en lugar de este archivo
# - Para más información, ver SETUP_GUIDE.md
